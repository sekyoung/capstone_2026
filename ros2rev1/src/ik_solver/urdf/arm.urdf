<?xml version="1.0"?>
<robot name="six_dof_arm">

  <!-- ── Materials ──────────────────────────────────────────────────── -->
  <material name="ivory">
    <color rgba="1.0 0.7 0.85 1.0"/>
  </material>
  <material name="ivory1">
    <color rgba="1.0 0.9 0.55 1.0"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1.0"/>
  </material>

  <!-- ── World root (required for robot_state_publisher / RViz2) ────── -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_motor"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── Base motor ─────────────────────────────────────────────────── -->
  <link name="base_motor">
    <visual>
      <origin xyz="0 0 0.0225" rpy="0 0 0"/>
      <geometry><box size="0.03 0.035 0.045"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0225" rpy="0 0 0"/>
      <geometry><box size="0.03 0.035 0.045"/></geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint_1: base yaw (rotates around parent-Y after -90° X tilt) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_motor"/>
    <child link="link_1"/>
    <origin xyz="0 0.0175 0.035" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="3.0" velocity="6.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.06"/></geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint_2: shoulder pitch -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.75" upper="1.75" effort="3.0" velocity="6.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.0365" rpy="0 0 0"/>
      <geometry><box size="0.05 0.03 0.1"/></geometry>
      <material name="ivory1"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0365" rpy="0 0 0"/>
      <geometry><box size="0.05 0.03 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.11"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint_3: forearm rotation -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="3.0" velocity="6.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.05"/></geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.06"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint_4: wrist pitch -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.09" upper="2.09" effort="3.0" velocity="6.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry><box size="0.05 0.02 0.07"/></geometry>
      <material name="ivory1"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry><box size="0.05 0.02 0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- joint_5: wrist rotation -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="3.0" velocity="6.0"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 0.0225" rpy="0 0 0"/>
      <geometry><box size="0.03 0.025 0.045"/></geometry>
      <material name="ivory"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0225" rpy="0 0 0"/>
      <geometry><box size="0.03 0.025 0.045"/></geometry>
    </collision>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- Fixed tip frame — gives a named TCP link for FK / RViz2 marker -->
  <joint name="joint_tcp" type="fixed">
    <parent link="link_5"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
  </joint>

  <link name="tcp"/>

</robot>
